<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="26dp">

            <LinearLayout
                android:id="@+id/homeContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layoutDirection="locale"
                android:orientation="vertical"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_max="680dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:id="@+id/headerText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        app:layout_constraintEnd_toStartOf="@id/brandPill"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="@string/brand_title"
                            android:textColor="@color/text_primary"
                            android:textSize="23sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:text="@string/brand_subtitle"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/brandPill"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_brand_pill"
                        android:gravity="center"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="dicodePing"
                        android:textColor="@color/brand"
                        android:textDirection="ltr"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/progressCard"
                    style="@style/Widget.DicodePing.Card.Compact"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="13dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="13dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/progressText"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textSize="12sp" />

                            <TextView
                                android:id="@+id/progressPercent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:textColor="@color/text_secondary"
                                android:textDirection="ltr"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <com.google.android.material.progressindicator.LinearProgressIndicator
                            android:id="@+id/progressBar"
                            android:layout_width="match_parent"
                            android:layout_height="4dp"
                            android:layout_marginTop="9dp"
                            app:indicatorColor="@color/brand"
                            app:trackColor="@color/surface_card_alt"
                            app:trackCornerRadius="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.DicodePing.Card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="13dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/statusDot"
                                android:layout_width="18dp"
                                android:layout_height="24dp"
                                android:gravity="center"
                                android:text="●"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/statusBadge"
                                android:layout_width="0dp"
                                android:layout_height="24dp"
                                android:layout_marginStart="4dp"
                                android:layout_weight="1"
                                android:gravity="start|center_vertical"
                                android:text="@string/ready_to_connect"
                                android:textColor="@color/text_secondary"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/statusTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/home_ready_title"
                            android:textColor="@color/text_primary"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/statusDetail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:maxLines="2"
                            android:minHeight="20dp"
                            android:text="@string/connection_status_hint"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <com.google.android.material.card.MaterialCardView
                            style="@style/Widget.DicodePing.Card.Flat"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp">

                            <androidx.constraintlayout.widget.ConstraintLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="86dp"
                                android:paddingStart="13dp"
                                android:paddingTop="12dp"
                                android:paddingEnd="13dp"
                                android:paddingBottom="12dp">

                                <TextView
                                    android:id="@+id/bestFlag"
                                    android:layout_width="50dp"
                                    android:layout_height="50dp"
                                    android:background="@drawable/bg_flag"
                                    android:gravity="center"
                                    android:text="🌐"
                                    android:textSize="24sp"
                                    app:layout_constraintBottom_toBottomOf="parent"
                                    app:layout_constraintStart_toStartOf="parent"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:id="@+id/recommendedLabel"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="12dp"
                                    android:text="@string/recommended_server"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="10sp"
                                    app:layout_constraintEnd_toEndOf="parent"
                                    app:layout_constraintStart_toEndOf="@id/bestFlag"
                                    app:layout_constraintTop_toTopOf="parent" />

                                <TextView
                                    android:id="@+id/bestServer"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text="@string/no_server"
                                    android:textColor="@color/text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    app:layout_constraintEnd_toEndOf="@id/recommendedLabel"
                                    app:layout_constraintStart_toStartOf="@id/recommendedLabel"
                                    app:layout_constraintTop_toBottomOf="@id/recommendedLabel" />

                                <TextView
                                    android:id="@+id/bestServerMeta"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:ellipsize="end"
                                    android:maxLines="1"
                                    android:text="@string/secure_server"
                                    android:textColor="@color/text_secondary"
                                    android:textDirection="locale"
                                    android:textSize="11sp"
                                    app:layout_constraintEnd_toEndOf="@id/bestServer"
                                    app:layout_constraintStart_toStartOf="@id/bestServer"
                                    app:layout_constraintTop_toBottomOf="@id/bestServer" />
                            </androidx.constraintlayout.widget.ConstraintLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.button.MaterialButton
        style="@style/Widget.DicodePing.Button.Primary"
                            android:id="@+id/connectButton"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:layout_marginTop="12dp"
                            android:text="@string/connect_best"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            app:cornerRadius="14dp"
                            app:icon="@drawable/ic_bolt"
                            app:iconGravity="textStart"
                            app:iconPadding="8dp"
                            app:iconSize="18dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/refreshButton"
                                style="@style/Widget.DicodePing.Button.OutlineCompact"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:text="@string/refresh_servers"
                                app:icon="@drawable/ic_servers"
                                app:iconGravity="textStart"
                                app:iconSize="17dp" />

                            <Space
                                android:layout_width="8dp"
                                android:layout_height="1dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/pingButton"
                                style="@style/Widget.DicodePing.Button.OutlineCompact"
                                android:layout_width="0dp"
                                android:layout_height="48dp"
                                android:layout_weight="1"
                                android:text="@string/ping_servers"
                                app:icon="@drawable/ic_bolt"
                                app:iconGravity="textStart"
                                app:iconSize="17dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/liveMetricsGroup"
                    style="@style/Widget.DicodePing.Card.Compact"
                    android:layout_width="match_parent"
                    android:layout_height="82dp"
                    android:layout_marginTop="10dp"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="7dp">

                            <TextView
                                android:id="@+id/downloadValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:maxLines="1"
                                android:text="0 B"
                                android:textColor="@color/text_primary"
                                android:textDirection="ltr"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="@string/session_download"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="42dp"
                            android:background="@color/outline_subtle" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="7dp">

                            <TextView
                                android:id="@+id/uploadValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:maxLines="1"
                                android:text="0 B"
                                android:textColor="@color/text_primary"
                                android:textDirection="ltr"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="@string/session_upload"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="42dp"
                            android:background="@color/outline_subtle" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="7dp">

                            <TextView
                                android:id="@+id/connectedPingValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:maxLines="1"
                                android:text="—"
                                android:textColor="@color/text_primary"
                                android:textDirection="ltr"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:text="@string/connected_ping"
                                android:textColor="@color/text_secondary"
                                android:textSize="10sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="@string/connection_overview"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.DicodePing.Card.Compact"
                    android:layout_width="match_parent"
                    android:layout_height="88dp"
                    android:layout_marginTop="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="7dp">

                            <TextView
                                android:id="@+id/savedValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:maxLines="1"
                                android:text="0"
                                android:textColor="@color/text_primary"
                                android:textDirection="ltr"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:maxLines="1"
                                android:text="@string/saved_servers"
                                android:textColor="@color/text_secondary"
                                android:textSize="9sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="44dp"
                            android:background="@color/outline_subtle" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="7dp">

                            <TextView
                                android:id="@+id/healthyValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:maxLines="1"
                                android:text="0"
                                android:textColor="@color/text_primary"
                                android:textDirection="ltr"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:maxLines="1"
                                android:text="@string/healthy_servers"
                                android:textColor="@color/text_secondary"
                                android:textSize="9sp" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="44dp"
                            android:background="@color/outline_subtle" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="7dp">

                            <TextView
                                android:id="@+id/bestValue"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:maxLines="1"
                                android:text="—"
                                android:textColor="@color/text_primary"
                                android:textDirection="ltr"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:maxLines="1"
                                android:text="@string/best_ping"
                                android:textColor="@color/text_secondary"
                                android:textSize="9sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
